generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CurrencyType {
  COINS
}

enum AllianceSubscriptionPermission {
  ANYONE
  MEMBERS
}

model CurrencySubmission {
  id            String           @id @default(uuid())
  submitterName String
  submitterUuid String
  submittedAt   DateTime         @default(now())
  modVersion    String
  records       CurrencyRecord[]

  @@index([submittedAt])
  @@map("currency_submissions")
}

model CurrencyRecord {
  id           String           @id @default(uuid())
  username     String
  uuid         String
  currencyType CurrencyType
  amount       BigInt

  submission   CurrencySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String

  @@index([uuid])
  @@index([submissionId])
  @@map("currency_records")
}

model Alliance {
  id                     String                         @id @db.Char(3)
  owner                  String
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")
  deletedAt              DateTime?                      @map("deleted_at")
  subscriptionPermission AllianceSubscriptionPermission @default(MEMBERS) @map("subscription_permission")
  data                   Json
  subscriptions          AllianceSubscription[]

  @@index([owner])
  @@index([deletedAt])
  @@map("alliance")
}

model AllianceSubscription {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  allianceId   String   @map("alliance_id") @db.Char(3)
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  alliance Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  @@unique([userId, allianceId])
  @@index([allianceId])
  @@index([userId])
  @@map("alliance_subscriptions")
}
